{
  "name": "purus",
  "version": "0.8.1",
  "description": "Purus - /ˈpuː.rus/ means pure✨ in Latin - is a beautiful, simple, and easy-to-use language. It compiles to JavaScript. It makes your fingers free from the Shift key. With Purus, you can write code almost without pressing the Shift key.",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "bin": {
    "purus": "bin/purus.js"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "bin/",
    "lib/",
    "LICENSE",
    "README.md",
    "README-ja.md"
  ],
  "scripts": {
    "test": "moon test",
    "build:compiler": "moon build --target js",
    "build:copy": "node scripts/build.js",
    "build": "npm run build:compiler && npm run build:copy",
    "lint": "moon check",
    "lint:fix": "moon fmt",
    "format": "moon fmt",
    "format:check": "moon fmt --check",
    "typecheck": "moon check",
    "check": "npm run lint && npm run format:check && npm run build && npm run typecheck",
    "sync": "node scripts/sync-version.js",
    "prepublishOnly": "npm run sync && npm run build"
  },
  "keywords": [
    "compiler",
    "language",
    "javascript",
    "transpiler",
    "altjs",
    "lang",
    "purus",
    "noshift"
  ],
  "author": "otoneko1102 (https://github.com/otoneko1102)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/otoneko1102/purus",
    "directory": "core"
  },
  "bugs": {
    "url": "https://github.com/otoneko1102/purus/issues"
  },
  "funding": {
    "url": "https://github.com/sponsors/otoneko1102"
  },
  "homepage": "https://purus.work",
  "engines": {
    "node": ">=18"
  }
}
