{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Purus",
  "scopeName": "source.purus",
  "patterns": [
    { "include": "#shebang" },
    { "include": "#comment-block" },
    { "include": "#comment-line" },
    { "include": "#string" },
    { "include": "#regex" },
    { "include": "#number" },
    { "include": "#declaration" },
    { "include": "#function" },
    { "include": "#control-flow" },
    { "include": "#module" },
    { "include": "#operator" },
    { "include": "#type-keyword" },
    { "include": "#constant" },
    { "include": "#other-keyword" },
    { "include": "#support" },
    { "include": "#punctuation" },
    { "include": "#identifier" }
  ],
  "repository": {
    "shebang": {
      "match": "\\A#!.*$",
      "name": "comment.line.shebang.purus"
    },
    "comment-line": {
      "match": "--(?!-).*$",
      "name": "comment.line.double-dash.purus"
    },
    "comment-block": {
      "begin": "---",
      "end": "---",
      "name": "comment.block.purus"
    },
    "string": {
      "begin": "///",
      "end": "///",
      "name": "string.quoted.triple-slash.purus",
      "patterns": [
        {
          "match": "\\\\[nt\\\\/\\[\\]]",
          "name": "constant.character.escape.purus"
        }
      ]
    },
    "regex": {
      "match": "(?<=[=\\[,;\\s])(/(?![/\\*])(?:[^/\\\\\\n]|\\\\.)+/[gimsuy]*)",
      "captures": {
        "1": { "name": "string.regexp.purus" }
      }
    },
    "number": {
      "patterns": [
        {
          "match": "\\b\\d+\\.\\d+\\b",
          "name": "constant.numeric.float.purus"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.purus"
        }
      ]
    },
    "declaration": {
      "match": "(?<![a-zA-Z0-9-])(const|let|var)(?![a-zA-Z0-9-])",
      "name": "storage.type.purus"
    },
    "function": {
      "patterns": [
        {
          "match": "(?<![a-zA-Z0-9-])(async)\\s+(fn)\\s+([a-zA-Z][a-zA-Z0-9-]*)",
          "captures": {
            "1": { "name": "storage.modifier.async.purus" },
            "2": { "name": "storage.type.function.purus" },
            "3": { "name": "entity.name.function.purus" }
          }
        },
        {
          "match": "(?<![a-zA-Z0-9-])(fn)\\s+([a-zA-Z][a-zA-Z0-9-]*)(?=\\s+[a-zA-Z]|\\s*$|\\s+to(?![a-zA-Z0-9-]))",
          "captures": {
            "1": { "name": "storage.type.function.purus" },
            "2": { "name": "entity.name.function.purus" }
          }
        },
        {
          "match": "(?<![a-zA-Z0-9-])(fn)(?![a-zA-Z0-9-])",
          "name": "storage.type.function.purus"
        }
      ]
    },
    "control-flow": {
      "patterns": [
        {
          "match": "(?<![a-zA-Z0-9-])(if|elif|else|unless|then)(?![a-zA-Z0-9-])",
          "name": "keyword.control.conditional.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(while|until|for|in|range)(?![a-zA-Z0-9-])",
          "name": "keyword.control.loop.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(match|when)(?![a-zA-Z0-9-])",
          "name": "keyword.control.match.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(try|catch|finally)(?![a-zA-Z0-9-])",
          "name": "keyword.control.trycatch.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(return|break|continue|throw)(?![a-zA-Z0-9-])",
          "name": "keyword.control.flow.purus"
        }
      ]
    },
    "module": {
      "patterns": [
        {
          "match": "(?<![a-zA-Z0-9-])(import|from|export|require|use|namespace|pub|all)(?![a-zA-Z0-9-])",
          "name": "keyword.control.import.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(default)(?![a-zA-Z0-9-])",
          "name": "keyword.control.default.purus"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "match": "(?<![a-zA-Z0-9-])(eq|is|be)(?![a-zA-Z0-9-])",
          "name": "keyword.other.equality.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(add|sub|mul|div|mod|neg|pow)(?![a-zA-Z0-9-])",
          "name": "keyword.control.arithmetic.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(neq|lt|gt|le|ge)(?![a-zA-Z0-9-])",
          "name": "keyword.operator.comparison.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(and|or|not)(?![a-zA-Z0-9-])",
          "name": "keyword.operator.logical.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(pipe)(?![a-zA-Z0-9-])",
          "name": "keyword.operator.pipe.purus"
        }
      ]
    },
    "type-keyword": {
      "match": "(?<![a-zA-Z0-9-])(as|of|gives|typeof|instanceof|type)(?![a-zA-Z0-9-])",
      "name": "keyword.other.type.purus"
    },
    "constant": {
      "patterns": [
        {
          "match": "(?<![a-zA-Z0-9-])(true|false)(?![a-zA-Z0-9-])",
          "name": "constant.language.boolean.purus"
        },
        {
          "match": "(?<![a-zA-Z0-9-])(null|nil|undefined)(?![a-zA-Z0-9-])",
          "name": "constant.language.purus"
        }
      ]
    },
    "other-keyword": {
      "match": "(?<![a-zA-Z0-9-])(new|delete|this|await)(?![a-zA-Z0-9-])",
      "name": "keyword.other.purus"
    },
    "support": {
      "match": "(?<![a-zA-Z0-9-])(list|object)(?![a-zA-Z0-9-])",
      "name": "support.type.purus"
    },
    "punctuation": {
      "patterns": [
        {
          "match": "\\[",
          "name": "punctuation.bracket.open.purus"
        },
        {
          "match": "\\]",
          "name": "punctuation.bracket.close.purus"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.purus"
        },
        {
          "match": ";",
          "name": "punctuation.separator.semicolon.purus"
        },
        {
          "match": "\\.",
          "name": "punctuation.accessor.purus"
        }
      ]
    },
    "identifier": {
      "patterns": [
        {
          "match": "(?<=\\.)([a-zA-Z][a-zA-Z0-9-]*)(?=\\[)",
          "name": "entity.name.function.method.purus"
        },
        {
          "match": "([a-zA-Z][a-zA-Z0-9-]*)(?=\\[)",
          "name": "entity.name.function.call.purus"
        },
        {
          "match": "\\b[A-Z][a-zA-Z0-9-]*\\b",
          "name": "support.class.purus"
        },
        {
          "match": "\\b[a-zA-Z][a-zA-Z0-9-]*\\b",
          "name": "variable.other.purus"
        }
      ]
    }
  }
}
